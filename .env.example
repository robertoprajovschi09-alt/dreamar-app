# drea.mar front-end environment — copy to `.env.local` and fill in.
# Only CLIENT-SAFE values belong here (Vite exposes VITE_* to the browser).

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The PUBLISHABLE / anon key (sb_publishable_... or the legacy anon JWT).
# This is safe to ship to the browser — RLS still protects every row.
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# NEVER put the SECRET key (sb_secret_... / service_role) in this file or any
# VITE_* var — it bypasses RLS and would be exposed to every visitor.
# Server secrets go to Supabase via:  supabase secrets set ANTHROPIC_API_KEY=... STRIPE_SECRET_KEY=...
# ---------------------------------------------------------------------------
